generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
  VOLUNTEER
}

enum CampaignStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SubscriptionInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAUSED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(VOLUNTEER)
  createdAt    DateTime   @default(now())
  lastLogin    DateTime?
  campaigns    Campaign[] @relation("CampaignCreator")
  events       Event[]    @relation("EventCreator")

  @@map("users")
}

model Campaign {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  summary       String
  content       Json
  goalAmount    Float
  raisedAmount  Float          @default(0)
  status        CampaignStatus @default(DRAFT)
  featuredImage String?
  startDate     DateTime?
  endDate       DateTime?
  tags          String[]
  createdBy     String
  creator       User           @relation("CampaignCreator", fields: [createdBy], references: [id])
  updatedAt     DateTime       @updatedAt
  createdAt     DateTime       @default(now())
  donations     Donation[]

  @@map("campaigns")
}

model Donation {
  id                String         @id @default(cuid())
  campaignId        String?
  campaign          Campaign?      @relation(fields: [campaignId], references: [id])
  donorName         String
  donorEmail        String
  amount            Float
  currency          String         @default("INR")
  razorpayOrderId   String?        @unique
  razorpayPaymentId String?        @unique
  status            DonationStatus @default(PENDING)
  receiptSent       Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("donations")
}

model Event {
  id           String      @id @default(cuid())
  title        String
  description  String
  location     String
  dateTime     DateTime
  capacity     Int
  signupsCount Int         @default(0)
  createdBy    String
  creator      User        @relation("EventCreator", fields: [createdBy], references: [id])
  volunteers   Volunteer[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("events")
}

model Volunteer {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String
  availability    String
  assignedEventId String?
  assignedEvent   Event?   @relation(fields: [assignedEventId], references: [id])
  notes           String?
  createdAt       DateTime @default(now())

  @@map("volunteers")
}

model ImpactStory {
  id          String   @id @default(cuid())
  title       String
  content     Json
  images      String[]
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("impact_stories")
}

model Subscription {
  id                     String               @id @default(cuid())
  donorId                String
  donorName              String
  donorEmail             String
  razorpaySubscriptionId String               @unique
  amount                 Float
  currency               String               @default("INR")
  interval               SubscriptionInterval @default(MONTHLY)
  status                 SubscriptionStatus   @default(ACTIVE)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@map("subscriptions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}